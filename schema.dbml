  "id_Servicio" int [not null, ref: > "dbo"."Servicio"."idServicio"]
}

Table "dbo"."CitaProgramada" {
  "idCitaProgramada" int [pk, not null, ref: - "dbo"."Triaje"."id_CitaProgramada", ref: - "dbo"."Atencion"."id_CitaProgramada", ref: - "dbo"."Venta"."id_Cita"]
  "id_Dueno" int [not null, ref: > "dbo"."Dueno"."idDueno"]
  "id_Programacion" int [not null, ref: > "dbo"."Programacion"."idProgramacion"]
