  "requiereTriaje" bit [not null]
  "estado" bit [not null]
  "fechaCreacion" datetime [not null]
  "fechaModificacion" datetime
  "fechaEliminacion" datetime
}

Table "dbo"."Dueno_Mascota" {
  "idDuenoMascota" int [pk, not null]
  "id_Dueno" int [ref: > "dbo"."Dueno"."idDueno"]
  "id_Mascota" int
  "id_Asociado" int [not null, ref: > "dbo"."Asociado"."idAsociado"]
}

Table "dbo"."Permiso" {
  "idPermiso" int [pk, not null, ref: > "dbo"."Rol_Permiso"."id_Permiso"]
